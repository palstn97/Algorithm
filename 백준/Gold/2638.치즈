'''
치즈가 바깥 공기에 2면 이상 닿아야 녹는다. 안쪽 갇힌 공기는 바깥 공기가 아니다!
'''
from collections import deque
import sys
input = sys.stdin.readline

def solve():    # 바깥 공기 bfs로 탐색하자.
    visited = [[False] * M for _ in range(N)]   # 바깥 공기 표시용 2차원 배열 -> False는 바깥공기가 아님!
    q = deque([(0, 0)])
    visited[0][0] = True    # visited[r][c] = True이면 바깥 공기 -> 모서리에서 시작해서 연결된 빈 칸을 따라가면 바깥 공기를 모두 찾을 수 있다.

    dr = [-1, 1, 0, 0]
    dc = [0, 0, -1, 1]

    while q:
        r, c = q.popleft()
        for i in range(4):
            nr = r + dr[i]
            nc = c + dc[i]
            if 0 <= nr < N and 0 <= nc < M:
                if not visited[nr][nc] and grid[nr][nc] == 0:
                    visited[nr][nc] = True
                    q.append((nr, nc))  # 4방향 탐색하면서 빈캄이고 아직 방문안했으면 바깥 공기로 표시하기. 치즈(1)은 통과하지 못하기에 안쪽 갇힌 공기는 visited가 되지 않는다! -> 통과 불가

    # bfs 끝난 후 치즈 녹이기 -> 모든 치즈 칸을 순회하면서 4방향 중 바깥 공기에 닿은 면이 2개 이상이면 녹을 치즈로 등록하기. 범위 체크 없는 이뉴는 문제 조건상 경계는 항상 0이라 치즈가 경계에 붙을 일이 없다.
    melt = []
    for r in range(N):
        for c in range(M):
            if grid[r][c] == 1: # 치즈인 칸만 검사
                cnt = 0
                for dr, dc in[(-1, 0), (1, 0), (0, -1), (0, 1)]:    # 치즈의 4방향을 보면서 바깥공기(visited == True)에 닿은 면 개수 세기!
                    nr, nc = r + dr, c + dc
                    if visited[nr][nc]:
                        cnt += 1    # 바깥 공기에 닿아있으면
                if cnt >= 2:    # 그래서 2개 이상이야?
                    melt.append((r, c)) # 그러면 녹는 치즈 리스트에 담아줘

    for r, c in melt:
        grid[r][c] = 0  # 왜 모았다가 하느냐? 먼저 검사한 치즈를 바로 0으로 만들면 옆 치즈 검사할 때 cnt가 달라진다. 그래서 한 턴 검사 다 끝내고 한꺼번에 제거해야 한다.

N, M = map(int, input().split())
grid = [list(map(int, input().split())) for _ in range(N)]

time = 0
while any(1 in row for row in grid):    # 그리드에 치즈가 하나라도 있으면 True, 치즈가 다 녹을 때까지 반복하기 -> 턴마다 bfs를 돌려야 한다!
    solve()
    time += 1

print(time)
